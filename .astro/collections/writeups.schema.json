{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "endDate": {
      "type": "string",
      "format": "date-time"
    },
    "icon": {
      "type": "string",
      "enum": [
        "Fingerprint",
        "Globe",
        "Binary",
        "Server"
      ]
    },
    "tags": {
      "minItems": 2,
      "maxItems": 5,
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9.-]+$"
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title"
  ]
}