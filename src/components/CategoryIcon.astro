---
interface Props {
  icon: 'Fingerprint' | 'Globe' | 'Binary' | 'Server';
}

const { icon } = Astro.props;
---

<svg class="category-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
  {icon === 'Fingerprint' && (
    <>
      <path d="M12 10a2 2 0 0 0-2 2c0 1-.1 2.5-.3 4" />
      <path d="M14 13.1c0 2.4 0 6.4-1 8.9" />
      <path d="M17.3 21c.1-.6.4-2.3.5-3" />
      <path d="M2 12a10 10 0 0 1 18-6" />
      <path d="M2 16h.01" />
      <path d="M21.8 16c.2-2 .1-5.4 0-6" />
      <path d="M5 19.5c.5-1.5 1-4.5 1-7.5A7 7 0 0 1 18 7.1" />
      <path d="M8.7 22c.2-.7.4-1.3.6-2" />
      <path d="M9 6.8a6 6 0 0 1 9 5.2v2" />
    </>
  )}
  {icon === 'Globe' && (
    <>
      <circle cx="12" cy="12" r="9" />
      <path d="M3 12h18M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18" />
    </>
  )}
  {icon === 'Binary' && (
    <>
      <rect x="3" y="4" width="6" height="8" rx="3" />
      <path d="M15 4h3v8M15 12h6M3 17h3v4M15 17h3v4M15 21h6" />
    </>
  )}
  {icon === 'Server' && (
    <>
      <rect x="3" y="4" width="18" height="6" rx="1" />
      <rect x="3" y="14" width="18" height="6" rx="1" />
      <path d="M7 7h.01M7 17h.01M11 7h7M11 17h7" />
    </>
  )}
</svg>
